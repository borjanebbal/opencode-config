{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-sonnet-4.6",
  "permission": {
    "bash": {
      // "ask" requires your confirmation before execution.
      "*": "ask",
      // "allow" lets common safe commands run without asking.
      "cat *": "allow",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "ls *": "allow",
      "npm test": "allow",
    },
    "skill": {
      // "ask" for any unlisted skill (catch-all, matched first).
      "*": "ask",
      "vercel-react-best-practices": "allow",
      "vue-best-practices": "allow",
      "nestjs-best-practices": "allow",
      "mcp-builder": "allow",
    },
  },
  "agent": {
    "plan": {
      "disable": true,
    },
  },
  "mcp": {
    "context7": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "pencil": {
      "enabled": false,
      "type": "local",
      "command": ["pencil", "mcp-server"],
    },
    "playwright": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
    },
  },
}
